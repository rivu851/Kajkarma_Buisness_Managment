# Node.js / TypeScript backend .gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

docs
# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by coverage tools
lib-cov

# Coverage directories
coverage/
.nyc_output/

# Build outputs
dist/
build/
out/

# TypeScript
*.tsbuildinfo

# Dependency directory
node_modules/

# Environment variables
.env
.env.*
.env.local

# Editor directories and files
.vscode/
.idea/
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
.cache/

# Lock files (if you're not using them)
# package-lock.json

# Testing
jest-cache/
coverage/

# Misc
*.tgz
*.local

# Docker
docker-compose.override.yml

# Secrets and keys
*.pem
*.key

# Logs produced by PM2
pm2.log

# Optional: ignore lockfile for other package managers (uncomment if needed)
# yarn.lock
# pnpm-lock.yaml
